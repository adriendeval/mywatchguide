{% extends "base.html.twig" %}

{% block body %}

<main class="container mx-auto mt-10">
	<div
		class="text-center">
		{% if username %}
			<h1 class="text-4xl font-bold mb-4">Bonjour {{ username }} !</h1>
		{% else %}
			<h1 class="text-4xl font-bold mb-4 text-blue-600">Bienvenue sur notre site !</h1>
			<p class="text-gray-700 text-lg">Inscrivez-vous ou connectez-vous à votre compte pour accéder aux fonctionnalités.</p>
			<a href="/register.php" class="mt-4 inline-block bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600">S'inscrire</a>
			<a href="/login.php" class="mt-4 inline-block bg-gray-500 text-white py-2 px-4 rounded hover:bg-gray-600 ml-2">Se connecter</a>
		{% endif %}
	</div>
</main>

{% endblock %}