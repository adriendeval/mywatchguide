{% extends "base.html.twig" %}

{% block body %}

<div class="container mx-auto px-4 py-8">
    <form action="search.php" method="post" class="bg-white shadow-lg rounded-lg p-8 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <label for="search_type" class="block text-gray-700 text-sm font-bold mb-2">Type de recherche :</label>
                <select name="search_type" id="search_type" class="block w-full border border-gray-300 rounded-lg py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="movie">Films</option>
                    <option value="tv">Séries</option>
                </select>
            </div>
            <div>
                <label for="search_term" class="block text-gray-700 text-sm font-bold mb-2">Terme de recherche :</label>
                <input type="text" name="search_term" id="search_term" required class="block w-full border border-gray-300 rounded-lg py-2 px-3 text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500" placeholder="Ex : Inception">
            </div>
        </div>
        <div class="mt-6 text-center">
            <button type="submit" class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-lg shadow-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                Rechercher
            </button>
        </div>
    </form>

    <h2 class="text-3xl font-semibold text-gray-800 mt-12 mb-6 text-center">Résultats de la recherche</h2>

    {% if results is not empty %}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for result in results %}
                <div class="bg-white shadow-md rounded-lg overflow-hidden">
                    {% if result.backdrop_path %}
                        <img src="https://image.tmdb.org/t/p/w780{{ result.backdrop_path }}" alt="{{ result.original_title }}" class="w-full h-64 object-cover">
                    {% else %}
                        <div class="flex items-center justify-center bg-gray-200 text-gray-500 text-sm font-medium h-64">
                            Image indisponible
                        </div>
                    {% endif %}
                    <div class="p-4">
                        <h3 class="text-lg font-semibold text-gray-900 mb-2">{{ result.original_title }}</h3>
                        <p class="text-gray-600 text-sm mb-4">{{ result.overview|slice(0, 256) ~ '...' }}</p>
                        <a href="https://www.themoviedb.org/{{ media_type }}/{{ result.id }}" target="_blank" class="text-blue-500 hover:underline font-medium">
                            Voir les détails
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="text-center text-gray-500 mt-8">Aucun résultat trouvé. Essayez un autre terme de recherche.</p>
    {% endif %}
</div>

{% endblock %}
