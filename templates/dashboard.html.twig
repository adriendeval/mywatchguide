{% extends "base.html.twig" %}

{% block body %}

    <div class="container mx-auto px-4">
        <h2 class="text-2xl font-bold mt-8 mb-6">Mes favoris</h2>

        {% if favorites is not empty %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"></div>
                {% for favorite in favorites %}
                    <div class="card bg-white shadow-md rounded-lg p-4">
                        <h3 class="text-lg font-semibold mb-2">{{ favorite.title }}</h3>
                        <p class="text-gray-600">{{ favorite.overview }}</p>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-500">Aucun favori trouvé.</p>
        {% endif %}

        {% if error is not empty %}
            <div class="alert bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mt-6">
                <strong class="font-bold">Erreur :</strong> 
                <span class="block sm:inline">{{ error }}</span>
            </div>
        {% endif %}
    </div>

{% endblock %}