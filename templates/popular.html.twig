{% extends "base.html.twig" %}

{% block body %}

<main class="container mx-auto py-8">
    {% if error %}
        <div class="bg-red-100 text-red-700 p-4 rounded mb-6">
            {{ error|raw }}
        </div>
    {% endif %}

    {# Films #}
    <section>
        <h2 class="text-3xl font-semibold mb-6 text-center">Films populaires</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {% if movies is not empty %}
                {% for movie in movies %}
                    <div class="bg-white shadow-md rounded-lg flex flex-col p-4 h-full relative">
                        {# Affichage de l'image du film avec badge #}
                        <div class="relative">
                            <img src="https://image.tmdb.org/t/p/w500{{ movie.poster_path }}" alt="{{ movie.title }}" class="mb-4 rounded">
                            {% if movie.release_date > "now"|date("Y-m-d") %}
                                <span class="absolute top-2 left-2 bg-gray-500 text-white text-xs font-semibold px-2 py-1 rounded-md">Pas sorti</span>
                            {% elseif movie.vote_average >= 7 %}
                                <span class="absolute top-2 left-2 bg-green-500 text-white text-xs font-semibold px-2 py-1 rounded-md">Très bien ({{ movie.vote_average|slice(0, 3) }}/10)</span>
                            {% elseif movie.vote_average >= 5 %}
                                <span class="absolute top-2 left-2 bg-yellow-500 text-white text-xs font-semibold px-2 py-1 rounded-md">Correct ({{ movie.vote_average|slice(0, 3) }}/10)</span>
                            {% elseif movie.vote_average < 5 %}
                                <span class="absolute top-2 left-2 bg-red-500 text-white text-xs font-semibold px-2 py-1 rounded-md">Mauvais ({{ movie.vote_average|slice(0, 3) }}/10)</span>
                            {% endif %}
                        </div>
                        <h3 class="text-lg font-semibold mb-2">{{ movie.title }}</h3>
                        <p class="text-gray-600 flex-grow">{{ movie.overview|slice(0, 128)|join(' ') ~ '...' }}</p>
                        <a href="https://www.themoviedb.org/movie/{{ movie.id }}" class="text-blue-500 hover:text-blue-700 underline mt-4 self-start transition duration-300 ease-in-out" target="_blank" title="Ouvrir dans un nouvel onglet">
                            <button class="bg-blue-500 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition duration-300 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                Voir les détails
                            </button>
                        </a>
                    </div>
                {% endfor %}
            {% else %}
                <p class="text-center text-gray-500">Aucun film populaire disponible.</p>
            {% endif %}
        </div>
    </section>

    {# Séries #}
    <section class="mt-12">
        <h2 class="text-3xl font-semibold mb-6 text-center">Séries populaires</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            {% if tv is not empty %}
                {% for series in tv %}
                    <div class="bg-white shadow-md rounded-lg flex flex-col p-4 h-full">
                        <img src="https://image.tmdb.org/t/p/w500{{ series.poster_path }}" alt="{{ series.original_name }}" class="mb-4 rounded">
                        <h3 class="text-lg font-semibold mb-2">{{ series.original_name }}</h3>
                        <p class="text-gray-600 flex-grow">{{ series.overview }}</p>
                        <a href="#" class="text-blue-500 hover:underline mt-4 self-start">Voir les détails</a>
                    </div>
                {% endfor %}
            {% else %}
                <p class="text-center text-gray-500">Aucune série populaire disponible.</p>
            {% endif %}
        </div>
    </section>
</main>

{% endblock %}